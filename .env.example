ANTAVO_BASE_URL=https://api.staging.antavo.com
ANTAVO_API_KEY=your_api_key_here
ANTAVO_API_SECRET=your_api_secret_here
# Do NOT include the date — the signing algorithm prepends it automatically
# Format: <env>/api/antavo_request  e.g. staging/api/antavo_request
ANTAVO_CREDENTIAL_SCOPE=staging/api/antavo_request
ANTAVO_CUSTOMER_ID=your-test-customer-uuid-here
